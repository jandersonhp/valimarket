@startuml valimarket

' =========================
' Classes principais
' =========================

class Produto {
  - nome: String
  - validade: Date
  - preco: float
  - precoDesconto: float
}

class Empresa {
  - nome: String
  - produtos: Produto[]
}

class Usuario {
  - nome: String
  - email: String
}

' =========================
' Classe do sistema (backend)
' =========================

class Sistema {
  + cadastrarProduto(produto: Produto)
  + listarProdutos(): Produto[]
  + listarProdutosProximos(): Produto[]
}

' =========================
' Relacionamentos
' =========================

Empresa "1" o-- "*" Produto : possui
Usuario --> Produto : visualiza
Sistema --> Produto
Sistema --> Empresa
Sistema --> Usuario

@enduml